# Frontend URL (Next.js)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Laravel API base URL (for endpoints like /api/login, /api/machines, etc.)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api

# Laravel base URL (useful for Sanctum CSRF cookie endpoint)
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Full Sanctum CSRF cookie endpoint (only if you use Laravel Sanctum)
NEXT_PUBLIC_SANCTUM_CSRF_URL=http://127.0.0.1:8000/sanctum/csrf-cookie
